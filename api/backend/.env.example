# Firebase Web API Key
# Firebase Console → Project Settings → General → Web API Key
# Bu key'i kopyalayıp aşağıya yapıştırın
FIREBASE_WEB_API_KEY=your-firebase-web-api-key-here

# CORS Allowed Origins
# Virgülle ayrılmış origin listesi
# Development için örnek:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
# Production için örnek:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Firebase Service Account (JSON format - güvenli yöntem)
# serviceAccountKey.json dosyası kullanmayın! JSON içeriğini bu variable'a koyun.
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Aldığınız JSON dosyasının içeriğini tek satır JSON olarak buraya yapıştırın:
# python3 -c "import json; data=json.load(open('serviceAccountKey.json')); print(json.dumps(data, separators=(',', ':')))"
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Firebase Service Account Path (Deprecated - serviceAccountKey.json yerine GOOGLE_APPLICATION_CREDENTIALS_JSON kullanın)
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

# Node Environment
# NODE_ENV=development

# Firebase Storage Bucket
# Firebase Console → Storage → Settings → Bucket name
# Yeni Firebase projeleri .firebasestorage.app formatını kullanır
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Rate Limiting (Development için daha yüksek limitler)
# Okuma işlemleri
RATE_LIMIT_READ_GENERAL=300
RATE_LIMIT_READ_ME=500

# Yazma işlemleri  
RATE_LIMIT_WRITE_CREATE=100
RATE_LIMIT_WRITE_UPDATE=150
RATE_LIMIT_WRITE_DELETE=50

# Auth işlemleri (development için)
RATE_LIMIT_AUTH_REGISTER=20
RATE_LIMIT_AUTH_REGISTER_DETAILS=30
RATE_LIMIT_AUTH_PASSWORD_RESET=20
RATE_LIMIT_AUTH_PASSWORD_CHANGE=30
RATE_LIMIT_AUTH_EMAIL_VERIFY=20

# Diğer işlemler
RATE_LIMIT_FILE_UPLOAD=50
RATE_LIMIT_STATS=100
RATE_LIMIT_BULK=50
RATE_LIMIT_OPENAPI=500
